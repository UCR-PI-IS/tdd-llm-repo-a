@page "/sedes/mostrar-sede/{CampusName}"

@using UCR.ECCI.PI.ThemePark.Frontend.Blazor.Application.Services
@using UCR.ECCI.PI.ThemePark.Frontend.Blazor.Domain.Entities.UniversityManagement
@using UCR.ECCI.PI.ThemePark.Frontend.Blazor.Presentation.Components

@inject ICampusServices CampusServices
@inject NavigationManager NavigationManager

<Breadcrumbs />
<PageTitle>Sede @campus?.Name.Name</PageTitle>

<h3>Detalles de la sede @campus?.Name.Name</h3>

@if (isLoading)
{
    <p><em>Cargando...</em></p>
}
else if (campus is not null)
{
    <FluidContainer>
        <!-- Header -->
        <MudText Typo="Typo.h6" Class="mb-4" Color="Color.Primary">
            <strong>Información de la sede</strong>
        </MudText>

        <!-- Campus Information -->
        <MudGrid Spacing="2" Class="mb-4">
            <TitleLabel Label="Nombre" />
            <ValueLabel Value="@campus.Name.Name" />

            <TitleLabel Label="Ubicación" />
            <ValueLabel Value="@campus.Location.Location" />

            <TitleLabel Label="Universidad" />
            <ValueLabel Value="@campus.University.Name.Name" />
        </MudGrid>

        <!-- Buttons -->
        <MudContainer Class="d-flex justify-end pa-0 mt-4">
            <MudButton Variant="Variant.Filled"
                       Color="Color.Error"
                       Class="mr-2"
                       OnClick="@DeleteCampus">
                Borrar
            </MudButton>
        </MudContainer>

        @if (showError)
        {
            <div class="alert alert-danger" role="alert">
                @errorMessage
            </div>
        }
    </FluidContainer>
}
else
{
    <p><em>Sede no encontrada.</em></p>
}

<PopupMessage @ref="_popupMessageRef"
              Title="Borrado Exitoso"
              Message="El campus ha sido <b>borrado</b> correctamente."
              OkText="OK"
              ColorVarOk="--color-primary3"
              OnAcknowledged="HandleOk" />

@code {
    [Parameter]
    public string CampusName { get; set; } = string.Empty;

    private Campus? campus;
    private bool isLoading = true;
    private bool showError = false;
    private string errorMessage = string.Empty;
    private PopupMessage? _popupMessageRef;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            campus = await CampusServices.GetByNameAsync(CampusName);
        }
        catch
        {
            campus = null;
        }
        finally
        {
            isLoading = false;
        }
    }

    private async Task DeleteCampus()
    {
        showError = false;
        errorMessage = string.Empty;

        try
        {
            var deleted = await CampusServices.DeleteCampusAsync(CampusName);

            if (deleted)
            {
                await _popupMessageRef!.ProgrammaticShow();
            }
            else
            {
                showError = true;
                errorMessage = "No se pudo eliminar la sede. Inténtalo de nuevo.";
            }
        }
        catch (Exception ex)
        {
            showError = true;
            errorMessage = $"Ocurrió un error inesperado: {ex.Message}";
        }
    }

    private void HandleOk()
    {
        NavigationManager.NavigateTo("/sedes");
    }
}
