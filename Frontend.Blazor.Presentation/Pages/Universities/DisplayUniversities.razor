@page "/universidades/mostrar-universidad/{UniversityName}"

@using UCR.ECCI.PI.ThemePark.Frontend.Blazor.Application.Services
@using UCR.ECCI.PI.ThemePark.Frontend.Blazor.Domain.Entities.UniversityManagement
@using UCR.ECCI.PI.ThemePark.Frontend.Blazor.Domain.ValueObjects.UniversityManagement
@using UCR.ECCI.PI.ThemePark.Frontend.Blazor.Presentation.Models
@using UCR.ECCI.PI.ThemePark.Frontend.Blazor.Presentation.Components

@inject IUniversityServices UniversityServices

<Breadcrumbs />
<PageTitle>Universidad @university?.Name.Name</PageTitle>

<h3>Detalles de la universidad @university?.Name.Name</h3>

@if (isLoading)
{
    <p><em>Cargando...</em></p>
}
else if (university is not null)
{

    <FluidContainer>
        <!-- Header -->
        <MudText Typo="Typo.h6" Class="mb-4" Color="Color.Primary">
            <strong>Información de la universidad</strong>
        </MudText>

        <MudGrid Spacing="2" Class="mb-4">
            <TitleLabel Label="Nombre" />
            <ValueLabel Value="@university.Name.Name" />

            <TitleLabel Label="País" />
            <ValueLabel Value="@($"{university.Country.Location}")" />
        </MudGrid>

        <!-- Buttons Container -->
        <MudContainer Class="d-flex justify-end pa-0 mt-4">
            <MudButton Variant="Variant.Filled"
                       Color="Color.Error"
                       Class="mr-2"
                       OnClick="@DeleteUniversity">
                Borrar
            </MudButton>
        </MudContainer>
    </FluidContainer>


    // Display error message if any
    @if (showError)
    {
        <div class="alert alert-danger" role="alert">
            @errorMessage
        </div>
    }
}
else
{
    <p><em>Edificio no encontrado.</em></p>
}

<PopupMessage @ref="_popupMessageRef"
              Title="Borrado Exitoso"
              Message="La universidad ha sido <b>borrada</b> correctamente."
              OkText="OK"
              ColorVarOk="--color-primary3"
              OnAcknowledged="HandleOk" />

@code {
    [Parameter]
    public string UniversityName { get; set; }

    private University? university;
    private bool isLoading = true;
    private PopupMessage? _popupMessageRef;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            university = await UniversityServices.GetByNameAsync(UniversityName);
        }
        catch
        {
            university = null;
        }
        finally
        {
            isLoading = false;
        }
    }


    [Inject] NavigationManager NavigationManager { get; set; } = default!;

    private bool showError = false;
    private string errorMessage = string.Empty;

    private async Task DeleteUniversity()
    {
        showError = false; // Reset error state
        errorMessage = string.Empty; // Clear previous error message

        try
        {
            var deleted = await UniversityServices.DeleteUniversityAsync(UniversityName);

            if (deleted)
            {
                await _popupMessageRef!.ProgrammaticShow();
            }
            else
            {
                showError = true;
                errorMessage = "Failed to delete the building. Please try again.";
            }
        }
        catch (Exception ex)
        {
            showError = true;
            errorMessage = $"An unexpected error occurred: {ex.Message}";
        }
    }

    private void HandleOk()
    {
        NavigationManager.NavigateTo("/universidades");
    }
}
