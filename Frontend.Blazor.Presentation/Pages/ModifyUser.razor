@page "/modify-user"

@using System.Text.RegularExpressions
@using UCR.ECCI.PI.ThemePark.Frontend.Blazor.Domain.Entities.AccountManagement
@using UCR.ECCI.PI.ThemePark.Frontend.Blazor.Presentation.Components
@using UCR.ECCI.PI.ThemePark.Frontend.Blazor.Application.Services
@using UCR.ECCI.PI.ThemePark.Frontend.Blazor.Application.Services.Implementations
@using UCR.ECCI.PI.ThemePark.Frontend.Blazor.Domain.Entities
@using UCR.ECCI.PI.ThemePark.Frontend.Blazor.Domain.ValueObjects.AccountManagement
@using MudBlazor

@inject UserNavigationContext NavContext
@inject IUserWithPersonService UserWithPersonService
@inject NavigationManager NavManager
@inject IRoleService RoleService
@inject ISnackbar Snackbar

<Header />
<MudBreadcrumbs Items="_items">
    <ItemTemplate Context="item">
        @if (item.Disabled)
        {
            <MudText Typo="Typo.subtitle2">@item.Text.ToUpper()</MudText>
        }
        else
        {
            <MudLink Href="@item.Href">@item.Text.ToUpper()</MudLink>
        }
    </ItemTemplate>
</MudBreadcrumbs>

<h3 class="mt-4 ms-3" style="color: #204C6F;">Información de Usuario</h3>
<div style="padding-bottom: 150px;">
    <div style="background-color: #f5f5f5; min-height: auto; padding-top: 2rem; padding-bottom: 3rem;">
        @if (User is not null)
        {
            <MudContainer MaxWidth="MaxWidth.False">

                @if (ShowError)
                {
                    <MudAlert Severity="Severity.Error" Class="mx-auto" Style="max-width: 1000px;">
                        @ErrorMessage
                    </MudAlert>
                }

                <MudPaper Class="mx-auto mt-4 px-6 py-4" Style="max-width: 1000px; border-radius: 8px;">
                    <MudGrid GutterSize="3">
                        <MudItem xs="6">
                            <MudTextField @bind-Value="User.FirstName"
                                          Label="Nombre"
                                          Variant="Variant.Filled"
                                          Dense="true"
                                          Style="width: 100%;" />
                        </MudItem>

                        <MudItem xs="6">
                            <MudTextField @bind-Value="User.Phone.Value"
                                          Label="Teléfono"
                                          Variant="Variant.Filled"
                                          Dense="true"
                                          Style="width: 100%;" />
                        </MudItem>

                        <MudItem xs="6">
                            <MudTextField @bind-Value="User.LastName"
                                          Label="Apellido"
                                          Variant="Variant.Filled"
                                          Dense="true"
                                          Style="width: 100%;" />
                        </MudItem>

                        <MudItem xs="6">
                            <MudTextField Value="@User.IdentityNumber?.Value"
                                          Label="Número de identificación"
                                          Variant="Variant.Filled"
                                          Dense="true"
                                          Disabled="true"
                                          Style="width: 100%;" />
                        </MudItem>

                        <MudItem xs="6">
                            <MudTextField @bind-Value="User.UserName.Value"
                                          Label="Nombre de usuario"
                                          Variant="Variant.Filled"
                                          Dense="true"
                                          Style="width: 100%;" />
                        </MudItem>

                        <MudItem xs="6">
                            <MudDatePicker @bind-Date="EditableBirthDate"
                                           Label="Fecha de nacimiento"
                                           Variant="Variant.Filled"
                                           Dense="true"
                                           PickerVariant="PickerVariant.Inline"
                                           OpenTo="OpenTo.Date"
                                           MaxDate="@DateTime.Today"
                                           Style="width: 100%;" />
                        </MudItem>

                        <MudItem xs="6">
                            <div style="display: flex; align-items: center; width: 100%;">
                                <MudSelect T="string"
                                           Label="Selecciona los roles"
                                           Variant="Variant.Filled"
                                           Dense="true"
                                           SelectedValues="SelectedRoleNames"
                                           SelectedValuesChanged="roles => SelectedRoleNames = roles.ToList()"
                                           MultiSelection="true"
                                           Style="height: 40px; width: 100%;">
                                    @foreach (var role in AvailableRoles)
                                    {
                                        <MudSelectItem T="string" Value="@role.Name">@role.Name</MudSelectItem>
                                    }
                                </MudSelect>
                            </div>
                        </MudItem>

                        <MudItem xs="6">
                            <MudTextField @bind-Value="User.Email.Value"
                                          Label="Correo electrónico"
                                          Variant="Variant.Filled"
                                          Dense="true"
                                          Style="width: 100%;" />
                        </MudItem>
                    </MudGrid>
                </MudPaper>

                <div class="d-flex justify-end mt-4" style="max-width: 1000px; margin: auto;">
                    <CustomButton ButtonType="cancel" Class="me-2" OnClick="@OnDeleteClicked">
                        CANCELAR
                    </CustomButton>

                    <CustomButton ButtonType="add" Variant="Variant.Filled" OnClick="@OnSaveClicked">
                        GUARDAR
                    </CustomButton>

                </div>
            </MudContainer>
        }
        else
        {
            <MudText Class="ms-4 mt-4">Cargando información del usuario...</MudText>
        }
    </div>
</div>

@code {
    private List<string> SelectedRoleNames { get; set; } = new();
    private List<Role> AvailableRoles = new();
    private UserWithPerson? User;
    private DateTime? EditableBirthDate;
    private bool ShowError = false;
    private string ErrorMessage = string.Empty;

    private List<BreadcrumbItem> _items = new()
    {
        new BreadcrumbItem("Home", href: "/"),
        new BreadcrumbItem("USER MANAGAMENT", href: "/user-management"),
        new BreadcrumbItem("USER DETAILS", href: "/user-details"), 
        new BreadcrumbItem("MODIFY USER", href: "/modify-user")
    };

    protected override async Task OnInitializedAsync()
    {
        if (NavContext.SelectedUserId.HasValue)
        {
            var users = await UserWithPersonService.GetAllUserWithPersonAsync();
            User = users.FirstOrDefault(u => u.UserId == NavContext.SelectedUserId);

            if (User?.Roles?.Any() == true)
                SelectedRoleNames = User.Roles.ToList();

            if (User?.BirthDate != null)
                EditableBirthDate = User.BirthDate.Value.ToDateTime(TimeOnly.MinValue);
        }

        AvailableRoles = await RoleService.GetAllRolesAsync();
    }

    private void OnDeleteClicked()
    {
        NavManager.NavigateTo("/user-management");
    }

    private async Task OnEditClicked()
    {
        ShowError = false;
        ErrorMessage = string.Empty;

        if (User is null)
            return;

        if (string.IsNullOrWhiteSpace(User.FirstName?.Trim()) || User.FirstName.Trim().Length > 50)
        {
            ShowError = true;
            ErrorMessage = "El nombre es obligatorio y debe tener como máximo 50 caracteres.";
            return;
        }

        if (string.IsNullOrWhiteSpace(User.LastName?.Trim()) || User.LastName.Trim().Length > 50)
        {
            ShowError = true;
            ErrorMessage = "El apellido es obligatorio y debe tener como máximo 50 caracteres.";
            return;
        }

        if (string.IsNullOrWhiteSpace(User.UserName?.Value) || !Regex.IsMatch(User.UserName.Value, @"^[a-z0-9._]{1,50}$"))
        {
            ShowError = true;
            ErrorMessage = "El nombre de usuario solo puede contener letras minúsculas, números, puntos y guiones bajos, sin espacios ni mayúsculas. Máximo 50 caracteres.";
            return;
        }

        if (string.IsNullOrWhiteSpace(User.Phone?.Value) || !Regex.IsMatch(User.Phone.Value, @"^\d{4}-\d{4}$"))
        {
            ShowError = true;
            ErrorMessage = "El teléfono debe tener el formato ####-####.";
            return;
        }

        if (string.IsNullOrWhiteSpace(User.Email?.Value) || !Regex.IsMatch(User.Email.Value, @"^[^@\s]+@[^@\s]+\.[^@\s]+$"))
        {
            ShowError = true;
            ErrorMessage = "El correo electrónico no tiene un formato válido.";
            return;
        }

        if (EditableBirthDate is null)
        {
            ShowError = true;
            ErrorMessage = "Debe ingresar una fecha de nacimiento válida.";
            return;
        }

        User.Roles = SelectedRoleNames;
        User.BirthDate = BirthDate.Create(DateOnly.FromDateTime(EditableBirthDate.Value));

        var success = await UserWithPersonService.UpdateUserWithPersonAsync(User);

        if (success)
        {
            Snackbar.Add("Usuario actualizado correctamente.", Severity.Success);
            NavManager.NavigateTo("/user-management");
        }
        else
        {
            Snackbar.Add("Hubo un error al actualizar el usuario.", Severity.Error);
        }
    }

    private async Task OnSaveClicked()
    {
        Snackbar.Add("Procesando actualización...", Severity.Info);
        await OnEditClicked();
    }
}
