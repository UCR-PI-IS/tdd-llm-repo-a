@page "/edificios/mostrar-edificio/{BuildingId:int}"

@using UCR.ECCI.PI.ThemePark.Frontend.Blazor.Application.Services
@using UCR.ECCI.PI.ThemePark.Frontend.Blazor.Domain.Entities.UniversityManagement
@using UCR.ECCI.PI.ThemePark.Frontend.Blazor.Domain.ValueObjects.UniversityManagement
@using UCR.ECCI.PI.ThemePark.Frontend.Blazor.Domain.Exceptions
@using UCR.ECCI.PI.ThemePark.Frontend.Blazor.Presentation.Models
@using UCR.ECCI.PI.ThemePark.Frontend.Blazor.Presentation.Components
@using UCR.ECCI.PI.ThemePark.Frontend.Blazor.Domain.Entities.Spaces

@inject IBuildingsServices BuildingsServices
@inject IFloorServices FloorServices

<Breadcrumbs />
<PageTitle>Edificio @building?.Name.Name</PageTitle>

<h3>Detalles del edificio @building?.Name.Name</h3>

@if (isLoading)
{
    <p><em>Cargando...</em></p>
}
else if (building is not null)
{
    <!-- Building Information Section -->
    <MudPaper Class="pa-4 mb-4" Style="background-color: #ffffff;">
        <!-- Header -->
        <MudText Typo="Typo.h6" Class="mb-4" Color="Color.Primary" Style="padding-left: 16px;">
            <strong>Información del edificio</strong>
        </MudText>

        <!-- Building Information -->
        <MudGrid Spacing="2" Class="mb-4" Style="padding-left: 16px;">
            <TitleLabel Label="Nombre" />
            <ValueLabel Value="@building.Name.Name" />

            <TitleLabel Label="Coordenadas" />
            <ValueLabel Value="@($"{building.BuildingCoordinates.X} {building.BuildingCoordinates.Y} {building.BuildingCoordinates.Z}")" />

            <TitleLabel Label="Dimensiones" />
            <ValueLabel Value="@($"{building.Dimensions.Length} x {building.Dimensions.Width} x {building.Dimensions.Height}")" />

            <TitleLabel Label="Color" />
            <ValueLabel Value="@TranslateColor(building.Color.Value)" />

            <TitleLabel Label="Área" />
            <ValueLabel Value="@building.Area.Name.Name" />

            <TitleLabel Label="Sede" />
            <ValueLabel Value="@building.Area.Campus.Name.Name" />

            <TitleLabel Label="Universidad" />
            <ValueLabel Value="@building.Area.Campus.University.Name.Name" />
        </MudGrid>

        <!-- Buttons Container -->
        <MudContainer Class="d-flex justify-end pa-0 mt-4">
            <MudButton Variant="Variant.Filled"
                       Color="Color.Error"
                       Class="mr-2"
                       OnClick="@DeleteBuilding">
                Borrar
            </MudButton>
            <MudButton Variant="Variant.Outlined"
                       Color="Color.Primary"
                       OnClick="@(() => NavigationManager.NavigateTo($"/edificios/editar-edificio/{@building.BuildingInternalId}"))">
                Editar
            </MudButton>
        </MudContainer>
    </MudPaper>

    <!-- Floor Management Section -->
    <MudPaper Class="pa-4 mt-6 mb-4" Style="background-color: #ffffff;">
        <!-- Header -->
        <MudText Typo="Typo.h6" Class="mb-4" Color="Color.Primary" Style="padding-left: 16px;">
            <strong>Pisos del edificio</strong>
        </MudText>

        <!-- Floor Selection and Buttons with standardized sizes -->
        <MudGrid Spacing="2" Class="mb-4" Style="padding-left: 16px;">
            <MudItem xs="12" md="6" Class="d-flex align-center">
                @if (_hasFloors)
                {
                    <MudSelect T="int"
                               Label="Pisos"
                               Variant="Variant.Outlined"
                               Value="@_floorSelectedNumber"
                               ValueChanged="OnFloorChanged"
                               Style="background: #ffffff; min-width: 250px;"
                               Class="my-2"
                               FullWidth="false">
                        @foreach (var floor in _floorsList!)
                        {
                            <MudSelectItem Value="@floor.Number.Value">@floor.Number.Value</MudSelectItem>
                        }
                    </MudSelect>
                }
                else
                {
                    <MudPaper Elevation="0" Class="d-flex align-center justify-start px-3"
                              Style="background-color: #f5f5f5; border: 1px solid #e0e0e0; border-radius: 4px; min-width: 250px;">
                        <MudText Typo="Typo.body1" Style="color: #9e9e9e;">Aún no existen pisos</MudText>
                    </MudPaper>
                }
            </MudItem>

            <MudItem xs="12" md="6" Class="d-flex align-center justify-end">
                <MudButton Variant="Variant.Outlined"
                           Color="Color.Primary"
                           StartIcon="@Icons.Material.Filled.Add"
                           Class="mr-2"
                           OnClick="@AddFloor">
                    Agregar Piso
                </MudButton>

                <MudButton Variant="Variant.Filled"
                           Color="Color.Error"
                           Icon="@Icons.Material.Filled.Delete"
                           Disabled="@(!_hasFloors)"
                           OnClick="@DeleteSelectedFloor">
                    Eliminar Piso
                </MudButton>
            </MudItem>
        </MudGrid>

        @if (_floorError)
        {
            <div class="alert alert-danger" role="alert" Style="margin-left: 16px; margin-right: 16px;">
                @errorMessage
            </div>
        }
    </MudPaper>

    // Display error message if any
    @if (showError)
    {
        <div class="alert alert-danger" role="alert">
            @errorMessage
        </div>
    }
}
else
{
    <p><em>Edificio no encontrado.</em></p>
}

@code {
    /// <summary>
    /// The unique identifier of the building to display.
    /// Extracted from the URL route parameter.
    /// </summary>
    [Parameter]
    public int BuildingId { get; set; }

    /// <summary>
    /// The building entity to be displayed with all its details.
    /// </summary>
    private Building? building;
    
    /// <summary>
    /// Indicates whether the component is currently loading data.
    /// </summary>
    private bool isLoading = true;

    /// <summary>
    /// The currently selected floor in the floors dropdown.
    /// </summary>
    private Floor? _floorSelected;
    
    /// <summary>
    /// The number of the currently selected floor.
    /// </summary>
    private int _floorSelectedNumber;
    
    /// <summary>
    /// Collection of all floors belonging to the current building.
    /// </summary>
    private List<Floor>? _floorsList;
    
    /// <summary>
    /// Indicates whether the building has any floors.
    /// </summary>
    private bool _hasFloors = false;
    
    /// <summary>
    /// Indicates whether there is an error related to floor operations.
    /// </summary>
    private bool _floorError = false;

    /// <summary>
    /// A dictionary to translate color names from English to Spanish.
    /// </summary>
    private readonly Dictionary<string, string> ColorTranslations = new()
    {
        { "Red", "Rojo" },
        { "Green", "Verde" },
        { "Blue", "Azul" },
        { "Yellow", "Amarillo" },
        { "Black", "Negro" },
        { "White", "Blanco" },
        { "Orange", "Naranja" },
        { "Purple", "Púrpura" },
        { "Gray", "Gris" },
        { "Brown", "Café" },
        { "Pink", "Rosado" },
        { "Cyan", "Cian" },
        { "Magenta", "Magenta" },
        { "Lime", "Lima" },
        { "Teal", "Turquesa" },
        { "Olive", "Olivo" },
        { "Navy", "Azul Marino" },
        { "Maroon", "Granate" },
        { "Silver", "Plata" },
        { "Gold", "Dorado" }
    };

    /// <summary>
    /// Used to translate color names from English to Spanish.
    /// </summary>
    /// <param name="englishColor">The value of the color in the database</param>
    /// <returns>The Spanish translation of the color name, or the original name if no translation exists</returns>
    private string TranslateColor(string englishColor)
    {
        return ColorTranslations.TryGetValue(englishColor, out var spanish) ? spanish : englishColor;
    }

    /// <summary>
    /// Initializes the component by loading the building details and its floors.
    /// </summary>
    /// <returns>A task representing the asynchronous operation</returns>
    protected override async Task OnInitializedAsync()
    {
        try
        {
            building = await BuildingsServices.DisplayBuildingAsync(BuildingId);
            await RefreshFloors();
        }
        catch
        {
            building = null;
        }
        finally
        {
            isLoading = false;
        }
    }

    /// <summary>
    /// Navigation manager for redirecting users after operations.
    /// </summary>
    [Inject] NavigationManager NavigationManager { get; set; } = default!;

    /// <summary>
    /// Indicates whether an error message should be displayed.
    /// </summary>
    private bool showError = false;
    
    /// <summary>
    /// Error message to display when operations fail.
    /// </summary>
    private string errorMessage = string.Empty;

    /// <summary>
    /// Deletes the current building after user confirmation.
    /// Navigates back to the buildings list on success.
    /// </summary>
    /// <returns>A task representing the asynchronous delete operation</returns>
    private async Task DeleteBuilding()
    {
        showError = false; // Reset error state
        errorMessage = string.Empty; // Clear previous error message

        try
        {
            var deleted = await BuildingsServices.DeleteBuildingAsync(BuildingId);

            if (deleted)
            {
                NavigationManager.NavigateTo("/edificios");
            }
            else
            {
                showError = true;
                errorMessage = "Failed to delete the building. Please try again.";
            }
        }
        catch (Exception ex)
        {
            showError = true;
            errorMessage = $"An unexpected error occurred: {ex.Message}";
        }
    }

    /// <summary>
    /// Refreshes the list of floors for the current building.
    /// Updates the selected floor and floor existence flag.
    /// </summary>
    /// <returns>A task representing the asynchronous refresh operation</returns>
    private async Task RefreshFloors()
    {
        _floorError = false;
        _floorsList = await FloorServices.GetFloorsListAsync(BuildingId);
        if (_floorsList != null && _floorsList.Count > 0)
        {
            _floorSelected = _floorsList[0];
            _floorSelectedNumber = _floorSelected.Number.Value;
            _hasFloors = true;
        }
        else
        {
            _floorsList = new List<Floor>();
            _hasFloors = false;
        }
    }

    /// <summary>
    /// Adds a new floor to the current building.
    /// Refreshes the floor list after successful addition.
    /// </summary>
    /// <returns>A task representing the asynchronous add operation</returns>
    private async Task AddFloor()
    {
        if (_floorsList == null)
        {
            _floorsList = new List<Floor>();
        }
        await FloorServices.CreateFloorAsync(BuildingId);
        await RefreshFloors();
        StateHasChanged();
    }

    /// <summary>
    /// Handles the selection change in the floor dropdown.
    /// Updates the currently selected floor.
    /// </summary>
    /// <param name="newFloor">The newly selected floor number</param>
    private void OnFloorChanged(int newFloor)
    {
        foreach (var floor in _floorsList!)
        {
            if (floor.Number.Value == newFloor)
            {
                _floorSelected = floor;
                _floorSelectedNumber = _floorSelected.Number.Value;
                break;
            }
        }
        StateHasChanged();
    }

    /// <summary>
    /// Deletes the currently selected floor.
    /// Handles any domain exceptions that might occur during deletion.
    /// </summary>
    /// <returns>A task representing the asynchronous delete operation</returns>
    private async Task DeleteSelectedFloor()
    {
        try
        {
            await FloorServices.DeleteFloorAsync(_floorSelected!.FloorId);
            await RefreshFloors();
            StateHasChanged();
        }
        catch (DomainException ex)
        {
            await RefreshFloors();
            StateHasChanged();
            errorMessage = ex.Message;
            _floorError = true;
        }
    }
}
