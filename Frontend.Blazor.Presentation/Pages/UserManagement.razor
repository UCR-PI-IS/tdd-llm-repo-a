@page "/user-management"

@* 
    UserManagement.razor
    --------------------
    This Blazor page provides a user management interface for the application.
    It displays a list of users with their associated personal information in a table.
    Features:
    - Fetches and displays all users with their personal details and roles.
    - Allows navigation to user details by clicking on a user's name.
    - Provides a button to add a new user.
    - Uses MudTable for tabular display with paging and horizontal scrolling.
    - Utilizes dependency injection for services and navigation context.
    - Integrates custom Header, Breadcrumbs, and Footer components.
*@

@using UCR.ECCI.PI.ThemePark.Frontend.Blazor.Domain.Entities.AccountManagement
@using UCR.ECCI.PI.ThemePark.Frontend.Blazor.Presentation.Components
@using UCR.ECCI.PI.ThemePark.Frontend.Blazor.Application.Services
@using UCR.ECCI.PI.ThemePark.Frontend.Blazor.Application.Services.Implementations
@using UCR.ECCI.PI.ThemePark.Frontend.Blazor.Domain.Entities
@using UCR.ECCI.PI.ThemePark.Frontend.Blazor.Domain.ValueObjects

@inject IUserWithPersonService UserWithPersonService
@inject NavigationManager NavManager
@inject UserNavigationContext NavContext

<Header />
<Breadcrumbs />

<div class="d-flex justify-content-center mt-4">
    <div style="min-width: 1000px;" class="d-flex justify-content-between align-items-center">
        <h3 class="mb-0" style="color: #204C6F;">Gestión de Usuarios</h3>
        <CustomButton ButtonType="add" Variant="Variant.Filled" OnClick="@OnAddUserClicked">
            AGREGAR USUARIO
        </CustomButton>
    </div>
</div>

<div class="d-flex justify-content-center">
    @if (isLoading)
    {
        <Spinner Size="Size.Large" Style="margin-top: 3rem;" />
    }
    else if (usersWithPerson is null || !usersWithPerson.Any())
    {
        <div class="mt-4 text-center" style="color: gray;">
            No hay usuarios para mostrar.
        </div>
    }
    else
    {
        <MudTable T="UserWithPerson"
                  Items="usersWithPerson"
                  Hover="true"
                  Dense="true"
                  Bordered="true"
                  Elevation="1"
                  Class="mt-4"
                  RowsPerPage="5"
                  Style="min-width: 1000px;">
            <HeaderContent>
                <MudTh class="no-wrap">Clave Usuario</MudTh>
                <MudTh class="no-wrap">Usuario</MudTh>
                <MudTh class="no-wrap">Nombre completo</MudTh>
                <MudTh class="no-wrap">Clave Persona</MudTh>
                <MudTh class="no-wrap">Correo</MudTh>
                <MudTh class="no-wrap">Teléfono</MudTh>
                <MudTh class="no-wrap">Identificación</MudTh>
                <MudTh class="no-wrap">Fecha de Nacimiento</MudTh>
                <MudTh class="no-wrap">Roles</MudTh>
            </HeaderContent>
            <RowTemplate>
                <MudTd class="no-wrap">@context.UserId</MudTd>
                <MudTd class="no-wrap">@context.UserName.Value</MudTd>
                <MudTd class="no-wrap">
                    <span class="mud-primary-text text-decoration-underline cursor-pointer"
                          style="cursor: pointer;"
                          @onclick="() => GoToUserDetails(context.UserId)">
                        @context.FirstName @context.LastName
                    </span>
                </MudTd>
                <MudTd class="no-wrap">@context.PersonId</MudTd>
                <MudTd class="no-wrap">@context.Email.Value</MudTd>
                <MudTd class="no-wrap">@context.Phone.Value</MudTd>
                <MudTd class="no-wrap">@context.IdentityNumber.Value</MudTd>
                <MudTd class="no-wrap">@context.BirthDate.Value.ToString("dd/MM/yyyy")</MudTd>
                <MudTd class="no-wrap">
                    @(context.Roles != null && context.Roles.Any() ? string.Join(", ", context.Roles) : "Sin rol")
                </MudTd>
            </RowTemplate>
            <PagerContent>
                <MudTablePager PageSizeOptions="new int[]{5, 10, 20}" />
            </PagerContent>
        </MudTable>
    }
</div>

@code {
    /// <summary>
    /// List of users with their associated personal information.
    /// </summary>
    private List<UserWithPerson>? usersWithPerson;

    private bool isLoading = true;
    /// <summary>
    /// Loads all users with their personal information when the page is initialized.
    /// </summary>
    protected override async Task OnInitializedAsync()
    {
        isLoading = true;
        usersWithPerson = await UserWithPersonService.GetAllUserWithPersonAsync();
        isLoading = false;
    }

    /// <summary>
    /// Navigates to the user details page for the selected user.
    /// </summary>
    /// <param name="userId">The ID of the selected user.</param>
    private void GoToUserDetails(int userId)
    {
        Console.WriteLine($"Seleccionado: {userId}");
        NavContext.SelectedUserId = userId;
        NavManager.NavigateTo("/user-details");
    }

    /// <summary>
    /// Navigates to the add user page when the add button is clicked.
    /// </summary>
    private void OnAddUserClicked()
    {
        Console.WriteLine("Add user clicked");
        NavManager.NavigateTo("/add-user");
    }
}