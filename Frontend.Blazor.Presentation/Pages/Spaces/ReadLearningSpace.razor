@page "/edificios/{buildingId:int}/pisos/{floorId:int}/espacios-de-aprendizaje/{learningSpaceId:int}"


@*
    ReadLearningSpace.razor
    -----------------------
    This Blazor page displays detailed information about a selected learning space,
    including its building, floor, and physical characteristics.
    It uses MudBlazor components for UI layout and styling.
    The learning space data is loaded based on the provided route parameters.
    The page provides "Delete" and "Edit" buttons for management actions.
*@

@using UCR.ECCI.PI.ThemePark.Frontend.Blazor.Domain.Entities.Spaces
@using UCR.ECCI.PI.ThemePark.Frontend.Blazor.Presentation.Components
@using UCR.ECCI.PI.ThemePark.Frontend.Blazor.Application.Services
@using UCR.ECCI.PI.ThemePark.Frontend.Blazor.Application.Services.Implementations
@using UCR.ECCI.PI.ThemePark.Frontend.Blazor.Domain.ValueObjects
@using MudBlazor

@inject NavigationManager Navigation

@inject ILearningSpaceServices LearningSpaceService
@inject IBuildingsServices BS
@inject IFloorServices FS

@if (isLoading)
{
    <div class="text-center my-3">
        <div class="spinner-border text-primary" role="status">
            <span class="visually-hidden">Cargando...</span>
        </div>
    </div>
}
else
{
    <Header />
    <Breadcrumbs />

    <h3 class="mt-4 ms-3" style="color: #204C6F;">Información del Espacio de Aprendizaje</h3>

    <div style="background-color: #f2f2f2; min-height: 100vh; padding-top: 2rem; padding-bottom: 3rem;">

        @* Display user information if loaded, otherwise show loading text *@
        @if (Space is not null)
        {
            <MudContainer MaxWidth="MaxWidth.Medium" Class="mt-6 page-background">
                <MudPaper Class="px-6 py-4" Elevation="1" Style="max-width: 1000px; margin: auto; border-radius: 8px;">
                    <MudGrid GutterSize="1">
                        <MudItem xs="12">
                            <MudText Class="fw-bold d-inline">Edificio: </MudText>
                            <MudText Class="d-inline ms-1">@building</MudText>
                        </MudItem>
                        <MudItem xs="12">
                            <MudText Class="fw-bold d-inline">Piso: </MudText>
                            <MudText Class="d-inline ms-1">@floor</MudText>
                        </MudItem>
                        <MudItem xs="12">
                            <MudText Class="fw-bold d-inline">Nombre: </MudText>
                            <MudText Class="d-inline ms-1">@Space.Name.Name</MudText>
                        </MudItem>
                        <MudItem xs="12">
                            <MudText Class="fw-bold d-inline">Tipo: </MudText>
                            <MudText Class="d-inline ms-1">@Space.Type.Value</MudText>
                        </MudItem>
                        <MudItem xs="12">
                            <MudText Class="fw-bold d-inline">Capacidad máxima: </MudText>
                            <MudText Class="d-inline ms-1">@Space.MaxCapacity.Value</MudText>
                        </MudItem>
                        <MudItem xs="12">
                            <MudText Class="fw-bold d-inline">Altura (m): </MudText>
                            <MudText Class="d-inline ms-1">@Space.Height.Value</MudText>
                        </MudItem>
                        <MudItem xs="12">
                            <MudText Class="fw-bold d-inline">Ancho (m): </MudText>
                            <MudText Class="d-inline ms-1">@Space.Width.Value</MudText>
                        </MudItem>
                        <MudItem xs="12">
                            <MudText Class="fw-bold d-inline">Largo (m): </MudText>
                            <MudText Class="d-inline ms-1">@Space.Length.Value</MudText>
                        </MudItem>
                    </MudGrid>

                </MudPaper>

                <div class="d-flex justify-end mt-4" style="max-width: 1000px; margin: auto;">
                    <MudButton Variant="Variant.Filled" Color="Color.Error" Class="me-2" OnClick="@OnDeleteClicked">
                        Eliminar
                    </MudButton>
                    <MudButton Variant="Variant.Outlined" OnClick="@OnEditClicked">
                        Editar
                    </MudButton>
                </div>
            </MudContainer>
        }
        else
        {
            <MudText Class="ms-4 mt-4" Color="Color.Error">No se encontró el espacio de aprendizaje.</MudText>
        }

        @if (!string.IsNullOrWhiteSpace(errorMessage))
        {
            <MudAlert Severity="Severity.Error" Elevation="0" Class="mx-4 my-2">
                @errorMessage
            </MudAlert>
        }
        @if (!string.IsNullOrWhiteSpace(successMessage))
        {
            <MudAlert Severity="Severity.Success" Elevation="0" Class="mx-4 my-2">
                @successMessage
            </MudAlert>
        }
    </div>
    <Footer />
}

@code {
    /// <summary>
    /// Route parameter: Building identifier.
    /// </summary>
    [Parameter]
    public int buildingId { get; set; }

    /// <summary>
    /// Route parameter: Floor identifier.
    /// </summary>
    [Parameter]
    public int floorId { get; set; }

    /// <summary>
    /// Route parameter: Learning space identifier.
    /// </summary>
    [Parameter]
    public int learningSpaceId { get; set; }

    /// <summary>
    /// Holds the user and person information to be displayed.
    /// </summary>
    private LearningSpace? Space;

    /// <summary>
    /// Indicates if the page is loading data.
    /// </summary>
    private bool isLoading = false;

    /// <summary>
    /// Message shown when an error occurs.
    /// </summary>
    private string errorMessage = "";

    /// <summary>
    /// Message shown when the operation is successful.
    /// </summary>
    private string successMessage = "";

    /// <summary>
    /// Stores the current floor number.
    /// </summary>
    private int floor = 0;

    /// <summary>
    /// Stores the current building name.
    /// </summary>
    private string building = "";

    /// <summary>
    /// Indicates if a delete operation is in progress.
    /// </summary>
    private bool isDeleting = false;


    /// <summary>
    /// Loads the user information when the page is initialized.
    /// </summary>
    protected override async Task OnInitializedAsync()
    {
        isLoading = true;
        try
        {
            // Fetch the learning space details using the provided learningSpaceId
            Space = await LearningSpaceService.GetLearningSpaceAsync(learningSpaceId);

            var buildingResult = await BS.DisplayBuildingAsync(buildingId);
            if (buildingResult != null && buildingResult.Name != null && !string.IsNullOrWhiteSpace(buildingResult.Name.Name))
            {
                building = buildingResult.Name.Name;
            }
            else
            {
                errorMessage = "No se pudo cargar el nombre del edificio.";
            }

            var floorList = await FS.GetFloorsListAsync(buildingId);
            if (floorList != null)
            {

                var currentFloor = floorList.FirstOrDefault(f => f.FloorId == floorId);
                if (currentFloor != null)
                {
                    floor = currentFloor.Number.Value;
                }
                else
                {
                    errorMessage = $"No se encontró el piso con ID {floorId}.";
                }
            }
            else
            {
                errorMessage = "No se pudieron obtener los pisos del edificio.";
            }
        }
        catch (Exception ex)
        {
            errorMessage = $"Error al recuperar los datos: {ex.Message}";
        }
        finally
        {
            isLoading = false;
        }
    }

    /// <summary>
    /// Handler for the Delete button click event.
    /// Deletes the current learning space and navigates back to the list.
    /// </summary>
    private async Task OnDeleteClicked()
    {
        isDeleting = true;
        errorMessage = "";
        successMessage = "";
        StateHasChanged();

        try
        {
            var deleted = await LearningSpaceService.DeleteLearningSpaceAsync(learningSpaceId);
            if (deleted)
            {
                successMessage = "¡Espacio eliminado correctamente!";
                StateHasChanged();
                await Task.Delay(3000);
                Navigation.NavigateTo($"/edificios/{buildingId}/espacios-de-aprendizaje");
            }
            else
            {
                errorMessage = "No se pudo eliminar el espacio. Intente de nuevo.";
            }
        }
        catch (Exception ex)
        {
            errorMessage = $"Error al eliminar el espacio: {ex.Message}";
        }
        finally
        {
            isDeleting = false;
            StateHasChanged();
        }
    }

    /// <summary>
    /// Handler for the Edit button click event.
    /// Navigates to the update page for the current learning space.
    /// </summary>
    private void OnEditClicked()
    {
        if (Space is not null)
        {
            Navigation.NavigateTo($"/edificios/{buildingId}/pisos/{floorId}/espacios-de-aprendizaje/{learningSpaceId}/actualizar");
        }
        else
        {
			errorMessage = "No se puede editar un espacio que no existe.";
        }
    }

}