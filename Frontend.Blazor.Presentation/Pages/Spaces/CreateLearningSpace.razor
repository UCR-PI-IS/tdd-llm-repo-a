@using Microsoft.Extensions.Logging
@using UCR.ECCI.PI.ThemePark.Frontend.Blazor.Application.Services
@using UCR.ECCI.PI.ThemePark.Frontend.Blazor.Domain.Entities.Spaces
@using UCR.ECCI.PI.ThemePark.Frontend.Blazor.Domain.Exceptions
@using UCR.ECCI.PI.ThemePark.Frontend.Blazor.Domain.ValueObjects.Spaces
@using UCR.ECCI.PI.ThemePark.Frontend.Blazor.Domain.ValueObjects.UniversityManagement
@using UCR.ECCI.PI.ThemePark.Frontend.Blazor.Presentation.Components
@using MudBlazor

@inject IBuildingsServices BS
@inject IFloorServices FS
@inject ILearningSpaceServices LS
@inject NavigationManager Navigation
@inject ILogger<CreateLearningSpace> Logger

@page "/edificios/{buildingId:int}/espacios-de-aprendizaje/crear"

<div style="overflow-y: auto; padding: 1rem; padding-bottom: 80px;">

<MudContainer MaxWidth="MaxWidth.Medium" Class="mt-6 page-background">
    <Breadcrumbs />

    <PageTitle>Creación del Espacio de Aprendizaje</PageTitle>

    <h1 class="custom-page-header">Creación del Espacio de Aprendizaje</h1>

    <MudPaper Class="pa-6 custom-paper">
        @if (this.IsLoading)
        {
            <MudProgressCircular Indeterminate="true"/>
        }
        else if (!this.IsBuildingValid || IsFloorListEmpty)
        {
            <MudAlert Severity="@(UserMessageSeverity)" Class="mb-4">@UserMessage</MudAlert>
            <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="@GoBuildings">Volver</MudButton>
        }
        else
        {
            <!-- Show the building and floor -->
            <MudText Typo="Typo.h5">Edificio: @this.BuildingName</MudText>

            <MudGrid Class="mt-4" GutterSize="3">
                <MudItem xs="12" sm="6">
                    <MudSelect T="int"
                        Label="Piso"
                        Variant="Variant.Filled"
                        Value="@this.FloorSelectedNumber"
                        ValueChanged="OnFloorChanged"
                        FitContent="true">
                            @foreach (var floor in this.FloorsList!)
                            {
                                <MudSelectItem Value="@floor.Number.Value">@floor.Number.Value</MudSelectItem>
                            }
                    </MudSelect>
                </MudItem>
            </MudGrid>

            <MudGrid Class="mt-4" GutterSize="3">
                <MudItem xs="12" sm="6">
                    <MudTextField @bind-Value="this.LearningSpaceName" Label="Nombre" Variant="Variant.Filled" />
                </MudItem>

                <MudItem xs="12" sm="6">
                    <MudTextField @bind-Value="this.Width" Label="Ancho (m)" Variant="Variant.Filled" />
                </MudItem>

                <MudItem xs="12" sm="6">
                    <MudTextField @bind-Value="this.MaxCapacity" Label="Capacidad máxima" Variant="Variant.Filled" />
                </MudItem>

                <MudItem xs="12" sm="6">
                    <MudTextField @bind-Value="this.Height" Label="Altura (m)" Variant="Variant.Filled" />
                </MudItem>

                <MudItem xs="12" sm="6">
                    <MudSelect T="string" Label="Tipo de espacio" Variant="Variant.Filled" @bind-Value="this.Type">
                        @foreach (var spaceType in spaceTypes)
                        {
                            <MudSelectItem Value="@spaceType.Value">@spaceType.Display</MudSelectItem>
                        }
                    </MudSelect>
                </MudItem>

                <MudItem xs="12" sm="6">
                    <MudTextField @bind-Value="Length" Label="Largo (m)" Variant="Variant.Filled" />
                </MudItem>
                </MudGrid>

            <div class="d-flex justify-end mt-6" style="gap: 1rem;">
                <MudButton Variant="Variant.Text" Color="Color.Primary" OnClick="@GoBack">Cancelar</MudButton>
                <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="@CreateLearningSpaceWeb">Crear</MudButton>
            </div>

            @if (!string.IsNullOrEmpty(UserMessage))
            {
                <MudAlert Severity="@(UserMessageSeverity)">@UserMessage</MudAlert>
            }
        }
    </MudPaper>
</MudContainer>
</div>
<Footer />

@code {
    /// <summary>
    /// Building Id of the learning space.
    /// </summary>
    [Parameter]
    public int buildingId { get; set; }

    /// <summary>
    /// Building name of the learning space.
    /// </summary>
    private string BuildingName = "";

    /// <summary>
    /// Floor list in the building.
    /// </summary>
    private List<Floor>? FloorsList;

    /// <summary>
    /// Floor selected number.
    /// </summary>
    private int FloorSelectedNumber;

    /// <summary>
    /// Floor selected for the learning space.
    /// </summary>
    private Floor? FloorSelected;

    /// <summary>
    /// Name of the learning space.
    /// </summary>
    private string LearningSpaceName = "";

    /// <summary>
    /// Type of the learning space.
    /// </summary>
    private string Type = "";

    /// <summary>
    /// Maximum capacity of the learning space.
    /// </summary>
    private int MaxCapacity;

    /// <summary>
    /// Height of the learning space in meters.
    /// </summary>
    private double Height;

    /// <summary>
    /// Width of the learning space in meters.
    /// </summary>
    private double Width;

    /// <summary>
    /// Length of the learning space in meters.
    /// </summary>
    private double Length;

    /// <summary>
    /// List of available space types for the form.
    /// </summary>
    private readonly List<(string Display, string Value)> spaceTypes = new()
    {
        ("Laboratorio", "Laboratory"),
        ("Aula", "Classroom"),
        ("Auditorio", "Auditorium")
    };

    /// <summary>
    /// User message to display on the form.
    /// </summary>
    private string UserMessage = "";

    /// <summary>
    /// User message severity to display on the form.
    /// </summary>
    private Severity UserMessageSeverity = Severity.Info;


    /// <summary>
    /// Shows whether the form is currently loading.
    /// </summary>
    private bool IsLoading = true;

    /// <summary>
    /// Shows whether the building is valid or not.
    /// </summary>
    private bool IsBuildingValid = true;


    /// <summary>
    /// Shows whether the floor list is empty or not.
    /// </summary>
    private bool IsFloorListEmpty = false;

    /// <summary>
    /// Creates a new learning space using the provided form data.
    /// </summary>
    /// <returns>
    /// A Task representing the asynchronous operation.
    /// </returns>
    private async Task CreateLearningSpaceWeb()
    {
        (bool isValid, string validationMsg) = ValidateLearningSpaceForm();
        if (!isValid)
        {
            this.UserMessage = validationMsg;
            this.UserMessageSeverity = Severity.Warning;
            return;
        }

        this.UserMessage = string.Empty;
        this.UserMessageSeverity = Severity.Info;

        try
        {
            var learningSpace = new LearningSpace(
                EntityName.Create(this.LearningSpaceName),
                LearningSpaceType.Create(this.Type),
                Capacity.Create(this.MaxCapacity),
                UCR.ECCI.PI.ThemePark.Frontend.Blazor.Domain.ValueObjects.Spaces.Size.Create(this.Height),
                UCR.ECCI.PI.ThemePark.Frontend.Blazor.Domain.ValueObjects.Spaces.Size.Create(this.Width),
                UCR.ECCI.PI.ThemePark.Frontend.Blazor.Domain.ValueObjects.Spaces.Size.Create(this.Length)
            );

            bool created = await LS.CreateLearningSpaceAsync(
                this.FloorSelected?.FloorId ?? 0,
                learningSpace);

            UserMessage = created
                ? "¡Se creó el espacio de aprendizaje correctamente!"
                : "No se pudo crear el espacio de aprendizaje.";
            UserMessageSeverity = created ? Severity.Success : Severity.Error;
        }
        catch (DomainException ex)
        {
            UserMessage = ex.Message;
            UserMessageSeverity = ex switch
            {
                ValidationException => Severity.Warning,
                DuplicatedEntityException => Severity.Error,
                NotFoundException => Severity.Error,
                _ => Severity.Error
            };
        }
        catch (Exception ex)
        {
            UserMessage = $"Ocurrió un error inesperado: {ex.Message}";
            UserMessageSeverity = Severity.Error;
        }
    }

    private (bool, string) ValidateLearningSpaceForm()
    {
        // Use value objects' TryCreate for validation and collect errors
        var errors = new List<string>();

        if (this.FloorSelectedNumber <= 0 || this.FloorSelected == null)
            errors.Add("Debe seleccionar un piso válido.");

        if (!EntityName.TryCreate(this.LearningSpaceName, out var learningSpaceName))
            errors.Add("El nombre es obligatorio y debe tener menos de 100 caracteres.");

        if (!Capacity.TryCreate(this.MaxCapacity, out var maxCapacity))
            errors.Add("La capacidad máxima debe ser un número entero positivo.");

        if (!LearningSpaceType.TryCreate(this.Type, out var learningSpaceType))
            errors.Add("Debe seleccionar un tipo de espacio válido.");

        if (!UCR.ECCI.PI.ThemePark.Frontend.Blazor.Domain.ValueObjects.Spaces.Size.TryCreate(this.Height, out var height))
            errors.Add("La altura debe ser un número positivo.");

        if (!UCR.ECCI.PI.ThemePark.Frontend.Blazor.Domain.ValueObjects.Spaces.Size.TryCreate(this.Width, out var width))
            errors.Add("El ancho debe ser un número positivo.");

        if (!UCR.ECCI.PI.ThemePark.Frontend.Blazor.Domain.ValueObjects.Spaces.Size.TryCreate(this.Length, out var length))
            errors.Add("El largo debe ser un número positivo.");

        if (errors.Count > 0)
            return (false, string.Join(" ", errors));

        return (true, string.Empty);
    }

    /// <summary>
    /// Navigates the user back to the previous page.
    /// </summary>
    private void GoBack()
    {
        Navigation.NavigateTo($"/edificios/{buildingId}/espacios-de-aprendizaje/");
    }

    /// <summary>
    /// Navigates the user back to the buildings page.
    /// </summary>
    private void GoBuildings()
    {
        Navigation.NavigateTo($"/edificios/");
    }

    /// <summary>
    /// Initializes the component by loading the building and its floors.
    /// </summary>
    /// <returns></returns>
    protected override async Task OnInitializedAsync()
    {
        this.IsLoading = true;
        bool buildingLoaded = false;
        try
        {
            var building = await BS.DisplayBuildingAsync(this.buildingId);

            if (building is null || string.IsNullOrWhiteSpace(building?.Name?.Name))
            {
                UserMessage = "No se encontró el edificio solicitado. Por favor, verifique la URL o contacte al administrador.";
                UserMessageSeverity = Severity.Error;
                this.IsBuildingValid = false;
                return;
            }

            this.BuildingName = building.Name.Name;
            this.IsBuildingValid = true;
            buildingLoaded = true;

            // Fetch floors for the building
            this.FloorsList = await FS.GetFloorsListAsync(buildingId);

            if (this.FloorsList != null && this.FloorsList.Count > 0)
            {
                this.FloorSelected = this.FloorsList[0];
                this.FloorSelectedNumber = this.FloorSelected.Number.Value;       
            }
            else
            {
                this.UserMessage = "El edificio no contiene pisos registrados.";
                this.UserMessageSeverity = Severity.Warning;
                this.IsFloorListEmpty = true;
            }
        }
        catch (Exception ex)
        {
            if (!buildingLoaded)
            {
                this.UserMessage = "Ocurrió un error al cargar la información del edificio.";
                this.IsBuildingValid = false;
            }
            else
            {
                this.UserMessage = "Ocurrió un error al cargar los pisos del edificio.";
                this.IsFloorListEmpty = true;
            }
            this.UserMessageSeverity = Severity.Error;
            Logger.LogError(ex, "Error during initialization of CreateLearningSpace");
        }
        finally
        {
            this.IsLoading = false;
        }
    }

    /// <summary>
    /// When the floor is changed, this method updates the selected floor and loads the learning spaces for that floor.
    /// </summary>
    /// <param name="newFloor"></param>
    /// <returns></returns>
    private Task OnFloorChanged(int newFloor)
    {
        var selected = this.FloorsList?.FirstOrDefault(f => f.Number.Value == newFloor);
        if (selected is not null)
        {
            this.FloorSelected = selected;
            this.FloorSelectedNumber = selected.Number.Value;
        }
        return Task.CompletedTask;
    }
}
