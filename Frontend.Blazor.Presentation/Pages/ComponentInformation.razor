@page "/edificios/{buildingId:int}/espacios-de-aprendizaje/{learningSpaceId:int}/listar-componentes/{ComponentId:int}"

@using UCR.ECCI.PI.ThemePark.Frontend.Blazor.Application.Services
@using UCR.ECCI.PI.ThemePark.Frontend.Blazor.Domain.Entities.ComponentsManagement
@using UCR.ECCI.PI.ThemePark.Frontend.Blazor.Presentation.Components

@* Dependency injection for required services *@
@inject ILearningComponentServices LearningComponentService
@inject NavigationManager NavigationManager
@inject IDialogService DialogService

@* Page that shows
    - Breadcrumb navigation component
    - Loading state while fetching data 
    - Learning component details if found
*@
<Breadcrumbs />

@if (isLoading)
{
    <PageTitle>Cargando componente...</PageTitle>
    <div class="d-flex flex-column align-items-center justify-content-center">
        <MudText Typo="Typo.h5">Cargando componente...</MudText>
        <Spinner Class="my-4"></Spinner>    
    </div>
}
else if (component is not null)
{
    <PageTitle>Componente @component.ComponentId</PageTitle>
    <MudText Typo="Typo.h5" Style="color: #204c6f;">
        Detalles del componente: @GetFormattedId(component)
    </MudText>

    <FluidContainer>
        <MudText Typo="Typo.h6" Class="mb-4" Color="Color.Primary">
            <strong>Información del componente</strong>
        </MudText>

        <MudGrid Spacing="2" Class="mb-4">
            <TitleLabel Label="ID" />
            <ValueLabel Value="@(component.ComponentId.ToString())" />

            <TitleLabel Label="Tipo" />
            <ValueLabel Value="@ComponentType" />

            <TitleLabel Label="Orientación" />
            <ValueLabel Value="@TranslateOrientation(component.Orientation.Value)" />

            <TitleLabel Label="Posición" />
            <ValueLabel Value="@($"{component.Position.X}, {component.Position.Y}")" />

            <TitleLabel Label="Dimensiones" />
            <ValueLabel Value="@($"{component.Dimensions.Width} x {component.Dimensions.Length} x {component.Dimensions.Height}")" />

            @if (component is Whiteboard whiteboard)
            {
                <TitleLabel Label="Color del marcador" />
                <ValueLabel Value="@TranslateColor(whiteboard.MarkerColor!.Value)" />
            }
            else if (component is Projector projector)
            {
                <TitleLabel Label="Área de proyección" />
                <ValueLabel Value="@($"{projector.ProjectionArea!.Length.ToString()} x {projector.ProjectionArea.Height.ToString()}")" />
                <TitleLabel Label="Contenido a proyectar" />
                <ValueLabel Value="@projector.ProjectedContent" />
            }
        </MudGrid>

        <MudContainer Class="d-flex justify-end pa-0 mt-4">
            <MudButton Variant="Variant.Filled" Color="Color.Error" OnClick="@OpenDeleteDialog" Disabled="@isDeleting" Class="mr-2">
                @if (isDeleting)
                {
                    <Spinner Size="Size.Small" Color="Color.Inherit" Class="mr-4"></Spinner>
                    <span>Eliminando...</span>
                }
                else
                {
                    <span>Eliminar</span>
                }
            </MudButton>
            <MudButton Variant="Variant.Outlined" Color="Color.Primary" OnClick="@(() => NavigationManager.NavigateTo($"/edificios/{@buildingId}/espacios-de-aprendizaje/{@learningSpaceId}/actualizar-componente/{@ComponentId}"))">
                Editar
            </MudButton>

            <MudMessageBox @ref="deleteDialog" Title="Confirmar eliminación" CancelText="Cancelar">
                <MessageContent>
                    ¿Está seguro que desea eliminar el componente @GetFormattedId(component)?
                </MessageContent>
                <YesButton>
                    <MudButton Variant="Variant.Filled" Color="Color.Error">Eliminar</MudButton>
                </YesButton>
            </MudMessageBox>

        </MudContainer>
    </FluidContainer>
}
else
{
    <PageTitle>Componente no encontrado</PageTitle>
    <h3>Componente no encontrado</h3>
    <p><em>Componente no encontrado.</em></p>
}

@* Display error message if one occurs *@
@if (showError)
{
    <div class="alert alert-danger mt-4" role="alert">
        @errorMessage
    </div>
}

@code {  
    /// <summary>
    /// The ID of the building Id from the route.
    /// Used to retrieve components associated with that space.
    /// </summary>
    [Parameter] public int buildingId { get; set; }
    /// <summary>
    /// Learning space ID from the route.
    /// </summary>
    [Parameter] public int learningSpaceId { get; set; }
    /// <summary>
    /// Component ID from the route.
    /// Used to fetch and display a specific component.
    /// </summary>
    [Parameter] public int ComponentId { get; set; }
    /// <summary>
    /// The learning component to display.
    /// </summary>
    private LearningComponent? component;
    /// <summary>
    /// Indicates if the page is currently loading data.
    /// </summary>
    private bool isLoading = true;
    /// <summary>
    /// Indicates if a delete operation is in progress.
    /// </summary>
    private bool isDeleting = false;
    /// <summary>
    /// Indicates if an error message should be shown.
    /// </summary>
    private bool showError = false;
    /// <summary>
    /// The error message to display if an error occurs.
    /// </summary>
    private string errorMessage = string.Empty;
    
    /// <summary>
    /// The message box to show when deleting a component.
    /// </summary>
    private MudMessageBox deleteDialog;

    /// <summary>
    /// Gets the type of the component as a string in Spanish.
    /// </summary>
    private string ComponentType => component switch
    {
        Projector => "Proyector",
        Whiteboard => "Pizarra",
        _ => "Componente"
    };

    /// <summary>
    /// English-to-Spanish orientation translations.
    /// </summary>
    private readonly Dictionary<string, string> ColorTranslations = new()
    {
        { "Red", "Rojo" },
        { "Green", "Verde" },
        { "Blue", "Azul" },
        { "Black", "Negro" },
        { "Orange", "Naranja" },
        { "Pink", "Rosado" }
    };

    /// <summary>
    /// Translates a color name from English to Spanish.
    /// </summary>
    private readonly Dictionary<string, string> OrientationTranslations = new()
    {
        { "North", "Norte" },
        { "South", "Sur" },
        { "East", "Este" },
        { "West", "Oeste" }

    };

    /// <summary>
    /// Used to translate color names from English to Spanish.
    /// </summary>
    /// <param name="englishColor">The value of the color in the database</param>
    /// <returns></returns>
    private string TranslateColor(string englishColor)
    {
        return ColorTranslations.TryGetValue(englishColor, out var spanish) ? spanish : englishColor;
    }

    /// <summary>
    /// Used to translate orientation names from English to Spanish.
    /// </summary>
    /// <param name="englishOrientation">The value of the orientation in the database</param>
    /// <returns></returns>
    private string TranslateOrientation(string englishOrientation)
    {
        return OrientationTranslations.TryGetValue(englishOrientation, out var spanish) ? spanish : englishOrientation;
    }

    /// <summary>
    /// Loads the component data when the page is initialized.
    /// </summary>
    protected override async Task OnInitializedAsync()
    {
        try
        {
            component = await LearningComponentService.GetSingleLearningComponentByIdAsync(ComponentId);
        }
        catch (Exception ex)
        {
            component = null;
            showError = true;
            errorMessage = $"Error al cargar componente: {ex.Message}";
        }
        finally
        {
            isLoading = false;
        }
    }

    /// <summary>
    /// Opens a confirmation dialog before deleting the component
    /// </summary>
    private async Task OpenDeleteDialog()
    {
        if (isDeleting || component == null)
            return;

        bool? result = await deleteDialog.ShowAsync();

        if (result == true)
        {
            await DeleteComponent();
        }
    }


    /// <summary>
    /// Handles the deletion of the current component. Shows a loading indicator and navigates back to the list on success.
    /// </summary>
    private async Task DeleteComponent()
    {
        if (isDeleting)
            return;

        isDeleting = true;

        showError = false;
        errorMessage = string.Empty;
        try
        {
            var deleted = await LearningComponentService.DeleteLearningComponentAsync(ComponentId);
            if (deleted)
            {
                NavigateToListComponent();
                isDeleting = false;
            }
            else
            {
                showError = true;
                errorMessage = "No se pudo borrar el componente.";
            }
        }
        catch (Exception ex)
        {
            showError = true;
            errorMessage = $"Error inesperado: {ex.Message}";
        }
    }

    /// <summary>
    /// Formats the component ID with a prefix based on type.
    /// </summary>
    private string GetFormattedId(LearningComponent component)
     {
            return component switch
            {
                Projector p => $"PROJ-{p.ComponentId}",
                Whiteboard w => $"WB-{w.ComponentId}",
                _ => component.ComponentId.ToString()
            };
     }

    private void NavigateToListComponent()
    {
        NavigationManager.NavigateTo($"/edificios/{@buildingId}/espacios-de-aprendizaje/{@learningSpaceId}/listar-componentes");
    }
}
